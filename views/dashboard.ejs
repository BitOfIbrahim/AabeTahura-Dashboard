<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="/static//Css/Login.css" rel="stylesheet" />



  <style>
    .wallet-banner {
      padding: 10px;
      border-radius: 10px;
      font-weight: bold;
    }
    .wallet-positive {
      background-color: #e8f5e9;
      color: #2e7d32;
    }
    .wallet-negative {
      background-color: #ffebee;
      color: #c62828;
    }
  </style>
</head>
<body>

<%
  let displayName = "User";
  if (reportData && reportData.length > 0) {
    const matched = reportData.find(row => row[1]);
    if (matched) displayName = matched[1];
  }
%>

<div class="container-fluid mt-5">
  <div class="logo-container">
    <img src="/Images/logo1.png">
  </div>

  <% if (typeof displayName !== 'undefined') { %>
    <div class="welcome-banner">
      <h2>Welcome, <span><%= displayName %></span> 👋</h2>
    </div>
  <% } %>

  <% if (typeof walletAmount !== 'undefined') {
      const walletClass = walletAmount >= 0 ? 'wallet-positive' : 'wallet-negative';
  %>
    <div class="wallet-banner text-center mt-3 mb-3 <%= walletClass %>">
      <h5>Your wallet price is <%= walletAmount %> PKR</h5>
    </div>
  <% } %>

  <div class="button-container d-flex justify-content-between align-items-center">
    <div class="left-buttons">
      <div id="duesSection" class="sticky-dues d-none d-md-block"></div>
    </div>
    <div class="right-buttons d-none d-md-flex">
      <button class="btn btn-danger" onclick="logout()">Logout</button>
    </div>
  </div>

  <div class="logout-top-mobile d-md-none">
    <button class="btn btn-danger" onclick="logout()">Logout</button>
  </div>

  <h1 class="dashboard-title text-center">Dashboard</h1>

  <!-- Wallet debug output -->
  <% if (typeof walletAmount !== 'undefined') { %>
    <script>
      console.log("DEBUG → walletAmount from backend:", <%- JSON.stringify(walletAmount) %>);
    </script>
  <% } else { %>
    <script>
      console.warn("DEBUG → walletAmount not provided by backend.");
    </script>
  <% } %>

  <!-- Filter Section -->
  <div class="d-flex justify-content-end mb-3">
    <label for="monthFilter" class="form-label me-2">Filter by Month:</label>
    <select id="monthFilter" class="form-select w-auto" onchange="filterTable()">
      <option value="all">All</option>
      <% for (let i = 1; i <= 12; i++) { %>
        <option value="<%= i %>">Month <%= i %></option>
      <% } %>
    </select>
  </div>

  <!-- Monthly Report Section -->
  <h2 class="text-center mt-4">Monthly Report</h2>
  <% if (monthlyReport && monthlyReport.length > 0) { %>
    <div class="table-responsive">
      <table id="monthlyReportTable" class="table table-bordered table-striped table-hover">
        <thead class="table-dark">
          <tr>
            <th>Month</th>
            <th>Bottle Consume</th>
            <th>Bill Amount</th>
            <th>Cash Paid</th>
          </tr>
        </thead>
        <tbody>
          <% monthlyReport.forEach(row => { %>
            <tr>
              <td><%= row[0] %></td>
              <td><%= row[5] %></td>
              <td><%= row[6] %></td>
              <td><%= row[7] %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      <p id="noDataMessageMonthly" class="text-center text-danger mt-3 d-none">No data found for this month in Monthly Report!</p>
    </div>
  <% } else { %>
    <p class="text-center text-danger">No data available for Monthly Report!</p>
  <% } %>

  <!-- Data List Section -->
  <h2 class="text-center mt-5">Data List</h2>
  <% if (dataList && dataList.length > 0) { %>
    <div class="table-responsive">
      <table id="dataListTable" class="table table-bordered table-striped table-hover">
        <thead class="table-dark">
          <tr>
            <th>Month</th>
            <th>Date</th>
            <th>Time</th>
            <th>Bottle Received</th>
            <th>Bottle Given</th>
            <th>Bill Amount</th>
            <th>Cash Received</th>
            <th>Wallet</th>
          </tr>
        </thead>
        <tbody>
          <% dataList.forEach(row => { %>
            <tr>
              <td><%= row[4] %></td>
              <td><%= row[2] %></td>
              <td><%= row[3] %></td>
              <td><%= row[12] %></td>
              <td><%= row[13] %></td>
              <td><%= row[14] %></td>
              <td><%= row[15] %></td>
              <td><%= row[27] %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      <p id="noDataMessageDataList" class="text-center text-danger mt-3 d-none">No data found for this month in DataList!</p>
    </div>
  <% } else { %>
    <p class="text-center text-danger">No data available for DataList!</p>
  <% } %>

  <!-- Customer Report Section -->
  <h2 class="text-center mt-5">Customer Report</h2>
  <% if (reportData && reportData.length > 0) { %>
    <div class="table-responsive">
      <table id="reportTable" class="table table-bordered table-striped table-hover">
        <thead class="table-dark">
          <tr>
            <th>S/No</th>
            <th>Status</th>
            <th>Bill Amount</th>
            <th>Name</th>
            <th>Easy Paisa N/O</th>
          </tr>
        </thead>
        <tbody>
          <% reportData.forEach(row => { %>
            <tr>
              <td><%= row[0] %></td>
              <td><%= row[3] %></td>
              <td><%= row[4] %></td>
              <td><%= row[1] %></td>
              <td><%= row[5] %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      <p id="noDataMessageReport" class="text-center text-danger mt-3 d-none">No data found for Customer Report!</p>
    </div>
  <% } else { %>
    <p class="text-center text-danger">No data available for Customer Report!</p>
  <% } %>

  <!-- Scripts -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const monthMapping = {
      "1": "Jan", "2": "Feb", "3": "March", "4": "April", "5": "May",
      "6": "June", "7": "July", "8": "Aug", "9": "Sep", "10": "Oct",
      "11": "Nov", "12": "Dec"
    };

  

    function filterTable() {
      const filterValue = document.getElementById("monthFilter").value;
      const normalizedFilter = monthMapping[filterValue] || filterValue;

      const monthlyReportRows = document.querySelectorAll("#monthlyReportTable tbody tr");
      let visibleMonthlyReportCount = 0;
      monthlyReportRows.forEach(row => {
        const monthCell = row.cells[0].textContent.trim();
        if (filterValue === "all" || monthCell === filterValue) {
          row.style.display = "";
          visibleMonthlyReportCount++;
        } else {
          row.style.display = "none";
        }
      });
      document.getElementById("noDataMessageMonthly").classList.toggle("d-none", visibleMonthlyReportCount > 0);

      const dataListRows = document.querySelectorAll("#dataListTable tbody tr");
      let visibleDataListCount = 0;
      dataListRows.forEach(row => {
        const monthCell = row.cells[0].textContent.trim();
        const normalizedMonthCell = monthMapping[monthCell] || monthCell;
        if (filterValue === "all" || normalizedMonthCell === normalizedFilter) {
          row.style.display = "";
          visibleDataListCount++;
        } else {
          row.style.display = "none";
        }
      });
      document.getElementById("noDataMessageDataList").classList.toggle("d-none", visibleDataListCount > 0);
    }
    
    function logout() {
      window.location.href = "/logout";
    }

  </script>
</body>
</html>
